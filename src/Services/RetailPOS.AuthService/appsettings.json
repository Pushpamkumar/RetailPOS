{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost\\SQLEXPRESS;Database=POS_AuthDB;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Jwt": {
    "Issuer": "RetailPOS",
    "Audience": "RetailPOS.Client",
    "PrivateKeyPath": "keys/private.pem",
    "PublicKeyPath": "keys/public.pem",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryHours": 8
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/auth-service-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "BusinessRules": {
    "BillHoldExpiryHours": 4,
    "MaxLoginAttempts": 5
  },
  "AllowedHosts": "*"
}
